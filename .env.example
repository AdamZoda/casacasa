# Supabase Configuration
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudflare Turnstile (public site key — exposed to the browser)
VITE_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
VITE_TURNSTILE_ENABLED=true

# Cloudflare Turnstile secret — server only (Vercel env + local .env for `npm run dev`)
# Never prefix with VITE_; do not commit the real value.
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# Application Configuration
APP_URL=http://localhost:3000
